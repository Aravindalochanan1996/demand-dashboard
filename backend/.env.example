# Copy this file to .env and fill in your own values

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=demand_dashboard

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS - your frontend URL
FRONTEND_ORIGIN=http://localhost:3000

# Powers the Resume Analyzer chatbot (and is available for future AI features
# in ATS Tracker / Resume Builder). Get a key from console.anthropic.com.
# Never put this in the frontend .env - it stays server-side only.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
